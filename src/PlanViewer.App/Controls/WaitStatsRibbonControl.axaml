<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PlanViewer.App.Controls.WaitStatsRibbonControl">
    <Border x:Name="RibbonBorder" Background="{DynamicResource BackgroundLightBrush}"
            CornerRadius="4" ClipToBounds="True"
            MinHeight="24">
        <Canvas x:Name="RibbonCanvas" Background="Transparent"/>
    </Border>
</UserControl>
