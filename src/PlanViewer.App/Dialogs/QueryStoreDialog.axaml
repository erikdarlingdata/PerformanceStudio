<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PlanViewer.App.Dialogs.QueryStoreDialog"
        Title="Query Store Analysis"
        Width="700" Height="520"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Icon="avares://PlanViewer.App/EDD.ico"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto">
        <!-- Options row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <StackPanel Spacing="4">
                <TextBlock Text="Top N" Foreground="{DynamicResource ForegroundBrush}" FontSize="11"/>
                <NumericUpDown x:Name="TopNBox" Value="10" Minimum="1" Maximum="50"
                               Width="100" Height="32" FontSize="13" FormatString="0"
                               HorizontalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Order by" Foreground="{DynamicResource ForegroundBrush}" FontSize="11"/>
                <ComboBox x:Name="OrderByBox" Width="180" Height="28" FontSize="12" SelectedIndex="0">
                    <ComboBoxItem Content="Total CPU" Tag="cpu"/>
                    <ComboBoxItem Content="Avg CPU" Tag="avg-cpu"/>
                    <ComboBoxItem Content="Total Duration" Tag="duration"/>
                    <ComboBoxItem Content="Avg Duration" Tag="avg-duration"/>
                    <ComboBoxItem Content="Total Reads" Tag="reads"/>
                    <ComboBoxItem Content="Avg Reads" Tag="avg-reads"/>
                    <ComboBoxItem Content="Total Writes" Tag="writes"/>
                    <ComboBoxItem Content="Avg Writes" Tag="avg-writes"/>
                    <ComboBoxItem Content="Total Physical Reads" Tag="physical-reads"/>
                    <ComboBoxItem Content="Avg Physical Reads" Tag="avg-physical-reads"/>
                    <ComboBoxItem Content="Total Memory Grant" Tag="memory"/>
                    <ComboBoxItem Content="Avg Memory Grant" Tag="avg-memory"/>
                    <ComboBoxItem Content="Executions" Tag="executions"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Hours back" Foreground="{DynamicResource ForegroundBrush}" FontSize="11"/>
                <NumericUpDown x:Name="HoursBackBox" Value="24" Minimum="1" Maximum="168"
                               Width="100" Height="32" FontSize="13" FormatString="0"
                               HorizontalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Spacing="4" VerticalAlignment="Bottom">
                <Button x:Name="FetchButton" Content="Fetch" Click="Fetch_Click"
                        Height="28" Padding="16,0" FontSize="12"
                        Theme="{StaticResource AppButton}"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" VerticalAlignment="Bottom" Margin="0,0,0,4"
                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
        </StackPanel>

        <!-- Column headers -->
        <Border Grid.Row="1" x:Name="HeaderRow" IsVisible="False"
                Background="{DynamicResource BackgroundDarkBrush}" Padding="8,4"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="30,70,70,120,100,*">
                <CheckBox Grid.Column="0" x:Name="SelectAllBox" IsChecked="True"
                          Click="SelectAll_Click" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Query ID" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Plan ID" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="MetricHeader" Text="Metric" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Executions" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Query Text" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Results list -->
        <ScrollViewer Grid.Row="2" x:Name="ResultsScroller"
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel x:Name="ResultsPanel" Spacing="0"/>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="LoadButton" Content="Load Selected" Click="Load_Click"
                    Height="32" Padding="16,0" FontSize="13" IsEnabled="False"
                    Theme="{StaticResource AppButton}"/>
            <Button Content="Cancel" Click="Cancel_Click"
                    Height="32" Padding="16,0" FontSize="13"
                    Theme="{StaticResource AppButton}"/>
        </StackPanel>
    </Grid>
</Window>
