                            @if (StmtPlan.MemoryGrant.RequiredMemoryKB > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Required</span><span class="prop-value">@FormatKB(StmtPlan.MemoryGrant.RequiredMemoryKB)</span></div>
                            }
                            @if (StmtPlan.MemoryGrant.SerialRequiredMemoryKB > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Serial Required</span><span class="prop-value">@FormatKB(StmtPlan.MemoryGrant.SerialRequiredMemoryKB)</span></div>
                            }
                            @if (StmtPlan.MemoryGrant.SerialDesiredMemoryKB > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Serial Desired</span><span class="prop-value">@FormatKB(StmtPlan.MemoryGrant.SerialDesiredMemoryKB)</span></div>
                            }
                            @if (StmtPlan.MemoryGrant.GrantWaitTimeMs > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Grant Wait Time</span><span class="prop-value">@FormatMs(StmtPlan.MemoryGrant.GrantWaitTimeMs)</span></div>
                            }
                            @if (StmtPlan.MemoryGrant.LastRequestedMemoryKB > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Last Requested</span><span class="prop-value">@FormatKB(StmtPlan.MemoryGrant.LastRequestedMemoryKB)</span></div>
                            }
                            @if (!string.IsNullOrEmpty(StmtPlan.MemoryGrant.IsMemoryGrantFeedbackAdjusted))
                            {
                                <div class="prop-row"><span class="prop-label">Feedback Adjusted</span><span class="prop-value">@StmtPlan.MemoryGrant.IsMemoryGrantFeedbackAdjusted</span></div>
                            }
                        </div>
                    </details>
                }

                @* Feature Flags (root only) *@
                @if (IsRoot && StmtPlan != null && (StmtPlan.ContainsInterleavedExecutionCandidates || StmtPlan.ContainsInlineScalarTsqlUdfs || StmtPlan.ContainsLedgerTables || StmtPlan.ExclusiveProfileTimeActive || StmtPlan.QueryCompilationReplay > 0 || StmtPlan.QueryVariantID > 0))
                {
                    <details class="prop-section">
                        <summary>Feature Flags</summary>
                        <div class="prop-grid">
                            @if (StmtPlan.ContainsInterleavedExecutionCandidates)
                            {
                                <div class="prop-row"><span class="prop-label">Interleaved Exec</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (StmtPlan.ContainsInlineScalarTsqlUdfs)
                            {
                                <div class="prop-row"><span class="prop-label">Inline Scalar UDFs</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (StmtPlan.ContainsLedgerTables)
                            {
                                <div class="prop-row"><span class="prop-label">Ledger Tables</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (StmtPlan.ExclusiveProfileTimeActive)
                            {
                                <div class="prop-row"><span class="prop-label">Exclusive Profile</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (StmtPlan.QueryCompilationReplay > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Compilation Replay</span><span class="prop-value">@StmtPlan.QueryCompilationReplay</span></div>
                            }
                            @if (StmtPlan.QueryVariantID > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Query Variant ID</span><span class="prop-value">@StmtPlan.QueryVariantID</span></div>
                            }
                        </div>
                    </details>
                }

                @* Set Options (root only) *@
                @if (IsRoot && StmtPlan?.SetOptions != null)
                {
                    <details class="prop-section">
                        <summary>Set Options</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">ANSI_NULLS</span><span class="prop-value">@(StmtPlan.SetOptions.AnsiNulls ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">ANSI_PADDING</span><span class="prop-value">@(StmtPlan.SetOptions.AnsiPadding ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">ANSI_WARNINGS</span><span class="prop-value">@(StmtPlan.SetOptions.AnsiWarnings ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">ARITHABORT</span><span class="prop-value">@(StmtPlan.SetOptions.ArithAbort ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">CONCAT_NULL</span><span class="prop-value">@(StmtPlan.SetOptions.ConcatNullYieldsNull ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">NUMERIC_ROUNDABORT</span><span class="prop-value">@(StmtPlan.SetOptions.NumericRoundAbort ? "ON" : "OFF")</span></div>
                            <div class="prop-row"><span class="prop-label">QUOTED_IDENTIFIER</span><span class="prop-value">@(StmtPlan.SetOptions.QuotedIdentifier ? "ON" : "OFF")</span></div>
                        </div>
                    </details>
                }

                @* Hardware Properties (root only) *@
                @if (IsRoot && StmtPlan?.HardwareProperties != null)
                {
                    <details class="prop-section">
                        <summary>Hardware</summary>
                        <div class="prop-grid">
                            @if (StmtPlan.HardwareProperties.EstimatedAvailableMemoryGrant > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Available Memory</span><span class="prop-value">@FormatKB(StmtPlan.HardwareProperties.EstimatedAvailableMemoryGrant)</span></div>
                            }
                            @if (StmtPlan.HardwareProperties.EstimatedPagesCached > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Pages Cached</span><span class="prop-value">@StmtPlan.HardwareProperties.EstimatedPagesCached.ToString("N0")</span></div>
                            }
                            @if (StmtPlan.HardwareProperties.EstimatedAvailableDOP > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Available DOP</span><span class="prop-value">@StmtPlan.HardwareProperties.EstimatedAvailableDOP</span></div>
                            }
                            @if (StmtPlan.HardwareProperties.MaxCompileMemory > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Max Compile Memory</span><span class="prop-value">@FormatKB(StmtPlan.HardwareProperties.MaxCompileMemory)</span></div>
                            }
                        </div>
                    </details>
                }

                @* Handles (root only) *@
                @if (IsRoot && StmtPlan != null && (!string.IsNullOrEmpty(StmtPlan.ParameterizedPlanHandle) || !string.IsNullOrEmpty(StmtPlan.BatchSqlHandle) || !string.IsNullOrEmpty(StmtPlan.DispatcherPlanHandle)))
                {
                    <details class="prop-section">
                        <summary>Handles</summary>
                        <div class="prop-grid">
                            @if (!string.IsNullOrEmpty(StmtPlan.ParameterizedPlanHandle))
                            {
                                <div class="prop-row full"><span class="prop-label">Parameterized Plan</span><span class="prop-value code">@StmtPlan.ParameterizedPlanHandle</span></div>
                            }
                            @if (!string.IsNullOrEmpty(StmtPlan.BatchSqlHandle))
                            {
                                <div class="prop-row full"><span class="prop-label">Batch SQL Handle</span><span class="prop-value code">@StmtPlan.BatchSqlHandle</span></div>
                            }
                            @if (!string.IsNullOrEmpty(StmtPlan.DispatcherPlanHandle))
                            {
                                <div class="prop-row full"><span class="prop-label">Dispatcher Plan</span><span class="prop-value code">@StmtPlan.DispatcherPlanHandle</span></div>
                            }
                        </div>
                    </details>
                }

                @* Trace Flags (root only) *@
                @if (IsRoot && StmtPlan != null && StmtPlan.TraceFlags.Count > 0)
                {
                    <details class="prop-section">
                        <summary>Trace Flags <span class="prop-warn-count">@StmtPlan.TraceFlags.Count</span></summary>
                        <div class="prop-grid">
                            @foreach (var tf in StmtPlan.TraceFlags)
                            {
                                <div class="prop-row"><span class="prop-label">TF @tf.Value</span><span class="prop-value">@tf.Scope@(tf.IsCompileTime ? " (compile)" : "")</span></div>
                            }
                        </div>
                    </details>
                }

                @* PSP Dispatcher (root only) *@
                @if (IsRoot && StmtPlan?.Dispatcher != null && (StmtPlan.Dispatcher.ParameterSensitivePredicates.Count > 0 || StmtPlan.Dispatcher.OptionalParameterPredicates.Count > 0))
                {
                    <details class="prop-section">
                        <summary>PSP Dispatcher</summary>
                        <div class="prop-grid">
                            @foreach (var psp in StmtPlan.Dispatcher.ParameterSensitivePredicates)
                            {
                                @if (!string.IsNullOrEmpty(psp.PredicateText))
                                {
                                    <div class="prop-row full"><span class="prop-label">Predicate</span><span class="prop-value code">@psp.PredicateText</span></div>
                                }
                                <div class="prop-row indent"><span class="prop-label">Range</span><span class="prop-value">[@psp.LowBoundary.ToString("N0") — @psp.HighBoundary.ToString("N0")]</span></div>
                                @foreach (var stat in psp.Statistics)
                                {
                                    <div class="prop-row indent"><span class="prop-label">@(!string.IsNullOrEmpty(stat.TableName) ? $"{stat.TableName}.{stat.StatisticsName}" : stat.StatisticsName)</span><span class="prop-value">Modified: @stat.ModificationCount.ToString("N0"), Sampled: @stat.SamplingPercent.ToString("F1")%</span></div>
                                }
                            }
                            @foreach (var opt in StmtPlan.Dispatcher.OptionalParameterPredicates)
                            {
                                @if (!string.IsNullOrEmpty(opt.PredicateText))
                                {
                                    <div class="prop-row full"><span class="prop-label">Optional</span><span class="prop-value code">@opt.PredicateText</span></div>
                                }
                            }
                        </div>
                    </details>
                }

                @* Cardinality Feedback (root only) *@
                @if (IsRoot && StmtPlan != null && StmtPlan.CardinalityFeedback.Count > 0)
                {
                    <details class="prop-section">
                        <summary>Cardinality Feedback</summary>
                        <div class="prop-grid">
                            @foreach (var cf in StmtPlan.CardinalityFeedback)
                            {
                                <div class="prop-row"><span class="prop-label">Node @cf.Key</span><span class="prop-value">@cf.Value.ToString("N0") rows</span></div>
                            }
                        </div>
                    </details>
                }

                @* Optimization Replay (root only) *@
                @if (IsRoot && StmtPlan != null && !string.IsNullOrEmpty(StmtPlan.OptimizationReplayScript))
                {
                    <details class="prop-section">
                        <summary>Optimization Replay</summary>
                        <div class="prop-grid">
                            <div class="prop-row full"><span class="prop-label"></span><span class="prop-value code">@StmtPlan.OptimizationReplayScript</span></div>
                        </div>
                    </details>
                }

                @* Template Plan Guide (root only) *@
                @if (IsRoot && StmtPlan != null && !string.IsNullOrEmpty(StmtPlan.TemplatePlanGuideName))
                {
                    <details class="prop-section">
                        <summary>Template Plan Guide</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">Name</span><span class="prop-value code">@StmtPlan.TemplatePlanGuideName</span></div>
                            @if (!string.IsNullOrEmpty(StmtPlan.TemplatePlanGuideDB))
                            {
                                <div class="prop-row"><span class="prop-label">Database</span><span class="prop-value code">@StmtPlan.TemplatePlanGuideDB</span></div>
                            }
                        </div>
                    </details>
                }

                @* Plan Version (root only) *@
                @if (IsRoot && Plan != null && (!string.IsNullOrEmpty(Plan.BuildVersion) || !string.IsNullOrEmpty(Plan.Build)))
                {
                    <details class="prop-section">
                        <summary>Plan Version</summary>
                        <div class="prop-grid">
                            @if (!string.IsNullOrEmpty(Plan.BuildVersion))
                            {
                                <div class="prop-row"><span class="prop-label">Build Version</span><span class="prop-value">@Plan.BuildVersion</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Plan.Build))
                            {
                                <div class="prop-row"><span class="prop-label">Build</span><span class="prop-value">@Plan.Build</span></div>
                            }
                            @if (Plan.ClusteredMode)
                            {
                                <div class="prop-row"><span class="prop-label">Clustered Mode</span><span class="prop-value flag">Yes</span></div>
                            }
                        </div>
                    </details>
                }

                @* Statistics Used (root only) *@
                @if (IsRoot && StmtPlan != null && StmtPlan.StatsUsage.Count > 0)
                {
                    <details class="prop-section">
                        <summary>Statistics Used <span class="prop-warn-count">@StmtPlan.StatsUsage.Count</span></summary>
                        <div class="prop-grid">
                            @foreach (var stat in StmtPlan.StatsUsage)
                            {
                                <div class="prop-row"><span class="prop-label">@(!string.IsNullOrEmpty(stat.TableName) ? $"{stat.TableName}.{stat.StatisticsName}" : stat.StatisticsName)</span><span class="prop-value">Mod: @stat.ModificationCount.ToString("N0"), @stat.SamplingPercent.ToString("F1")%@(!string.IsNullOrEmpty(stat.LastUpdate) ? $", {stat.LastUpdate}" : "")</span></div>
                            }
                        </div>
                    </details>
                }

                @* Thread Stats (root only) *@
                @if (IsRoot && StmtPlan?.ThreadStats != null)
                {
                    <details class="prop-section">
                        <summary>Thread Stats</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">Branches</span><span class="prop-value">@StmtPlan.ThreadStats.Branches</span></div>
                            <div class="prop-row"><span class="prop-label">Used Threads</span><span class="prop-value">@StmtPlan.ThreadStats.UsedThreads</span></div>
                            @if (StmtPlan.ThreadStats.Reservations.Sum(r => r.ReservedThreads) > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Reserved Threads</span><span class="prop-value">@StmtPlan.ThreadStats.Reservations.Sum(r => r.ReservedThreads)</span></div>
                                @foreach (var res in StmtPlan.ThreadStats.Reservations)
                                {
                                    <div class="prop-row indent"><span class="prop-label">Node @res.NodeId</span><span class="prop-value">@res.ReservedThreads reserved</span></div>
                                }
                            }
                        </div>
                    </details>
                }

                @* Query Time Stats (root only) *@
                @if (IsRoot && StmtPlan?.QueryTimeStats != null)
                {
                    <details class="prop-section">
                        <summary>Query Time Stats</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">CPU Time</span><span class="prop-value">@FormatMs(StmtPlan.QueryTimeStats.CpuTimeMs)</span></div>
                            <div class="prop-row"><span class="prop-label">Elapsed Time</span><span class="prop-value">@FormatMs(StmtPlan.QueryTimeStats.ElapsedTimeMs)</span></div>
                            @if (StmtPlan.QueryUdfCpuTimeMs > 0)
                            {
                                <div class="prop-row"><span class="prop-label">UDF CPU Time</span><span class="prop-value">@FormatMs(StmtPlan.QueryUdfCpuTimeMs)</span></div>
                            }
                            @if (StmtPlan.QueryUdfElapsedTimeMs > 0)
                            {
                                <div class="prop-row"><span class="prop-label">UDF Elapsed Time</span><span class="prop-value">@FormatMs(StmtPlan.QueryUdfElapsedTimeMs)</span></div>
                            }
                        </div>
                    </details>
                }

                @* Indexed Views (root only, statement-level) *@
                @if (IsRoot && StmtPlan != null && StmtPlan.IndexedViews.Count > 0)
                {
                    <details class="prop-section">
                        <summary>Indexed Views</summary>
                        <div class="prop-grid">
                            @foreach (var iv in StmtPlan.IndexedViews)
                            {
                                <div class="prop-row full"><span class="prop-label">View</span><span class="prop-value code">@iv</span></div>
                            }
                        </div>
                    </details>
                }

            </div>
        </aside>

@code {
    [Parameter] public PlanNode Node { get; set; } = default!;
    [Parameter] public PlanStatement? StmtPlan { get; set; }
    [Parameter] public ParsedPlan? Plan { get; set; }
    [Parameter] public bool IsRoot { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
