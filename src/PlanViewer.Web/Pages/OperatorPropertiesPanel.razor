                            {
                                <div class="prop-row"><span class="prop-label">@np.Name</span><span class="prop-value code">@(np.ScalarString ?? "")</span></div>
                            }
                        </div>
                    </details>
                }

                @* Operator Indexed Views *@
                @if (Node.OperatorIndexedViews.Count > 0)
                {
                    <details class="prop-section">
