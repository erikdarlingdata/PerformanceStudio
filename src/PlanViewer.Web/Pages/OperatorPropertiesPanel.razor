        <aside class="properties-panel">
            <div class="prop-header">
                <div class="prop-header-info">
                    <img src="icons/@(Node.IconName).png" class="prop-header-icon" alt="" />
                    <div>
                        <div class="prop-header-op">@GetOperatorLabel(Node)</div>
                        <div class="prop-header-sub">Node @Node.NodeId · Cost: @(Node.CostPercent)%</div>
                    </div>
                </div>
                <button class="prop-close" @onclick="OnClose" title="Close">&times;</button>
            </div>

            <div class="prop-body">

                @* General *@
                <details class="prop-section" open>
                    <summary>General</summary>
                    <div class="prop-grid">
                        <div class="prop-row"><span class="prop-label">Physical Op</span><span class="prop-value">@Node.PhysicalOp</span></div>
                        <div class="prop-row"><span class="prop-label">Logical Op</span><span class="prop-value">@Node.LogicalOp</span></div>
                        <div class="prop-row"><span class="prop-label">Node ID</span><span class="prop-value">@Node.NodeId</span></div>
                        @if (!string.IsNullOrEmpty(Node.ExecutionMode))
                        {
                            <div class="prop-row"><span class="prop-label">Execution Mode</span><span class="prop-value">@Node.ExecutionMode</span></div>
                        }
                        @if (!string.IsNullOrEmpty(Node.ActualExecutionMode) && Node.ActualExecutionMode != Node.ExecutionMode)
                        {
                            <div class="prop-row"><span class="prop-label">Actual Exec Mode</span><span class="prop-value">@Node.ActualExecutionMode</span></div>
                        }
                        <div class="prop-row"><span class="prop-label">Parallel</span><span class="prop-value">@(Node.Parallel ? "True" : "False")</span></div>
                        @if (Node.Partitioned)
                        {
                            <div class="prop-row"><span class="prop-label">Partitioned</span><span class="prop-value flag">Yes</span></div>
                        }
                        @if (Node.EstimatedDOP > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Estimated DOP</span><span class="prop-value">@Node.EstimatedDOP</span></div>
                        }
                        @if (!string.IsNullOrEmpty(Node.FullObjectName))
                        {
                            <div class="prop-row"><span class="prop-label">Ordered</span><span class="prop-value">@(Node.Ordered ? "True" : "False")</span></div>
                            @if (!string.IsNullOrEmpty(Node.ScanDirection))
                            {
                                <div class="prop-row"><span class="prop-label">Scan Direction</span><span class="prop-value">@Node.ScanDirection</span></div>
                            }
                            <div class="prop-row"><span class="prop-label">Forced Index</span><span class="prop-value">@(Node.ForcedIndex ? "True" : "False")</span></div>
                            <div class="prop-row"><span class="prop-label">ForceScan</span><span class="prop-value">@(Node.ForceScan ? "True" : "False")</span></div>
                            <div class="prop-row"><span class="prop-label">ForceSeek</span><span class="prop-value">@(Node.ForceSeek ? "True" : "False")</span></div>
                            <div class="prop-row"><span class="prop-label">NoExpandHint</span><span class="prop-value">@(Node.NoExpandHint ? "True" : "False")</span></div>
                            @if (Node.Lookup)
                            {
                                <div class="prop-row"><span class="prop-label">Lookup</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.DynamicSeek)
                            {
                                <div class="prop-row"><span class="prop-label">Dynamic Seek</span><span class="prop-value flag">Yes</span></div>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Node.StorageType))
                        {
                            <div class="prop-row"><span class="prop-label">Storage</span><span class="prop-value">@Node.StorageType</span></div>
                        }
                        @if (Node.IsAdaptive)
                        {
                            <div class="prop-row"><span class="prop-label">Adaptive</span><span class="prop-value flag">Yes</span></div>
                        }
                        @if (Node.SpillOccurredDetail)
                        {
                            <div class="prop-row"><span class="prop-label">Spill Occurred</span><span class="prop-value flag warn">Yes</span></div>
                        }
                    </div>
                </details>

                @* Object *@
                @if (!string.IsNullOrEmpty(Node.ObjectName))
                {
                    <details class="prop-section" open>
                        <summary>Object</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">Name</span><span class="prop-value code">@(Node.FullObjectName ?? Node.ObjectName)</span></div>
                            @if (!string.IsNullOrEmpty(Node.IndexName))
                            {
                                <div class="prop-row"><span class="prop-label">Index</span><span class="prop-value code">@Node.IndexName</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.IndexKind))
                            {
                                <div class="prop-row"><span class="prop-label">Index Kind</span><span class="prop-value">@Node.IndexKind</span></div>
                            }
                            @if (Node.FilteredIndex)
                            {
                                <div class="prop-row"><span class="prop-label">Filtered</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.ObjectAlias))
                            {
                                <div class="prop-row"><span class="prop-label">Alias</span><span class="prop-value code">@Node.ObjectAlias</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.DatabaseName))
                            {
                                <div class="prop-row"><span class="prop-label">Database</span><span class="prop-value">@Node.DatabaseName</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.ServerName))
                            {
                                <div class="prop-row"><span class="prop-label">Server</span><span class="prop-value">@Node.ServerName</span></div>
                            }
                            @if (Node.TableReferenceId > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Table Ref ID</span><span class="prop-value">@Node.TableReferenceId</span></div>
                            }
                        </div>
                    </details>
                }

                @* Costs *@
                <details class="prop-section" open>
                    <summary>Costs</summary>
                    <div class="prop-grid">
                        <div class="prop-row"><span class="prop-label">Operator Cost</span><span class="prop-value">@Node.EstimatedOperatorCost.ToString("N4") (@(Node.CostPercent)%)</span></div>
                        <div class="prop-row"><span class="prop-label">Subtree Cost</span><span class="prop-value">@Node.EstimatedTotalSubtreeCost.ToString("N4")</span></div>
                        <div class="prop-row"><span class="prop-label">I/O Cost</span><span class="prop-value">@Node.EstimateIO.ToString("N4")</span></div>
                        <div class="prop-row"><span class="prop-label">CPU Cost</span><span class="prop-value">@Node.EstimateCPU.ToString("N4")</span></div>
                    </div>
                </details>

                @* Rows *@
                <details class="prop-section" open>
                    <summary>Rows</summary>
                    <div class="prop-grid">
                        <div class="prop-row"><span class="prop-label">Est. Executions</span><span class="prop-value">@((1 + Node.EstimateRebinds).ToString("N0"))</span></div>
                        <div class="prop-row"><span class="prop-label">Est. Rows Per Exec</span><span class="prop-value">@Node.EstimateRows.ToString("N1")</span></div>
                        <div class="prop-row"><span class="prop-label">Est. Rows All Execs</span><span class="prop-value">@((Node.EstimateRows * Math.Max(1, 1 + Node.EstimateRebinds)).ToString("N1"))</span></div>
                        @if (Node.EstimatedRowsRead > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Est. Rows Read</span><span class="prop-value">@Node.EstimatedRowsRead.ToString("N0")</span></div>
                        }
                        @if (Node.EstimatedRowSize > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Avg Row Size</span><span class="prop-value">@Node.EstimatedRowSize B</span></div>
                        }
                        @if (Node.TableCardinality > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Table Cardinality</span><span class="prop-value">@Node.TableCardinality.ToString("N0")</span></div>
                        }
                        @if (Node.EstimateRebinds > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Est. Rebinds</span><span class="prop-value">@Node.EstimateRebinds.ToString("N2")</span></div>
                        }
                        @if (Node.EstimateRewinds > 0)
                        {
                            <div class="prop-row"><span class="prop-label">Est. Rewinds</span><span class="prop-value">@Node.EstimateRewinds.ToString("N2")</span></div>
                        }
                        @if (Node.EstimateRowsWithoutRowGoal > 0 && Math.Abs(Node.EstimateRowsWithoutRowGoal - Node.EstimateRows) > 0.01)
                        {
                            <div class="prop-row"><span class="prop-label">Est. Rows (No Goal)</span><span class="prop-value">@Node.EstimateRowsWithoutRowGoal.ToString("N0")</span></div>
                        }
                    </div>
                </details>

                @* Actual Statistics *@
                @if (Node.HasActualStats)
                {
                    <details class="prop-section" open>
                        <summary>Actual Statistics</summary>
                        <div class="prop-grid">
                            <div class="prop-row"><span class="prop-label">Actual Rows</span><span class="prop-value">@Node.ActualRows.ToString("N0")</span></div>
                            @if (Node.PerThreadStats.Count > 1)
                            {
                                @foreach (var t in Node.PerThreadStats)
                                {
                                    <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualRows.ToString("N0")</span></div>
                                }
                            }
                            @if (Node.ActualRowsRead > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Actual Rows Read</span><span class="prop-value">@Node.ActualRowsRead.ToString("N0")</span></div>
                                @if (Node.PerThreadStats.Count > 1)
                                {
                                    @foreach (var t in Node.PerThreadStats.Where(t => t.ActualRowsRead > 0))
                                    {
                                        <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualRowsRead.ToString("N0")</span></div>
                                    }
                                }
                            }
                            <div class="prop-row"><span class="prop-label">Actual Executions</span><span class="prop-value">@Node.ActualExecutions.ToString("N0")</span></div>
                            @if (Node.PerThreadStats.Count > 1)
                            {
                                @foreach (var t in Node.PerThreadStats)
                                {
                                    <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualExecutions.ToString("N0")</span></div>
                                }
                            }
                            @if (Node.ActualRebinds > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Actual Rebinds</span><span class="prop-value">@Node.ActualRebinds.ToString("N0")</span></div>
                            }
                            @if (Node.ActualRewinds > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Actual Rewinds</span><span class="prop-value">@Node.ActualRewinds.ToString("N0")</span></div>
                            }
                            @if (Node.PartitionsAccessed > 0)
                            {
                                <div class="prop-row"><span class="prop-label">Partitions Accessed</span><span class="prop-value">@Node.PartitionsAccessed</span></div>
                                @if (!string.IsNullOrEmpty(Node.PartitionRanges))
                                {
                                    <div class="prop-row"><span class="prop-label">Partition Ranges</span><span class="prop-value code">@Node.PartitionRanges</span></div>
                                }
                            }
                        </div>
                    </details>

                    @* Actual Timing *@
                    @if (Node.ActualElapsedMs > 0 || Node.ActualCPUMs > 0 || Node.UdfCpuTimeMs > 0 || Node.UdfElapsedTimeMs > 0)
                    {
                        <details class="prop-section" open>
                            <summary>Actual Timing</summary>
                            <div class="prop-grid">
                                @if (Node.ActualElapsedMs > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Elapsed Time</span><span class="prop-value">@FormatMs(Node.ActualElapsedMs)</span></div>
                                    @if (Node.PerThreadStats.Count > 1)
                                    {
                                        @foreach (var t in Node.PerThreadStats.Where(t => t.ActualElapsedMs > 0))
                                        {
                                            <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@FormatMs(t.ActualElapsedMs)</span></div>
                                        }
                                    }
                                }
                                @if (Node.ActualCPUMs > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">CPU Time</span><span class="prop-value">@FormatMs(Node.ActualCPUMs)</span></div>
                                    @if (Node.PerThreadStats.Count > 1)
                                    {
                                        @foreach (var t in Node.PerThreadStats.Where(t => t.ActualCPUMs > 0))
                                        {
                                            <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@FormatMs(t.ActualCPUMs)</span></div>
                                        }
                                    }
                                }
                                @if (Node.UdfElapsedTimeMs > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">UDF Elapsed</span><span class="prop-value">@FormatMs(Node.UdfElapsedTimeMs)</span></div>
                                }
                                @if (Node.UdfCpuTimeMs > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">UDF CPU</span><span class="prop-value">@FormatMs(Node.UdfCpuTimeMs)</span></div>
                                }
                            </div>
                        </details>
                    }

                    @* Actual I/O *@
                    @if (Node.ActualLogicalReads > 0 || Node.ActualPhysicalReads > 0 || Node.ActualScans > 0 || Node.ActualReadAheads > 0 || Node.ActualSegmentReads > 0 || Node.ActualSegmentSkips > 0)
                    {
                        <details class="prop-section" open>
                            <summary>Actual I/O</summary>
                            <div class="prop-grid">
                                <div class="prop-row"><span class="prop-label">Logical Reads</span><span class="prop-value">@Node.ActualLogicalReads.ToString("N0")</span></div>
                                @if (Node.PerThreadStats.Count > 1)
                                {
                                    @foreach (var t in Node.PerThreadStats.Where(t => t.ActualLogicalReads > 0))
                                    {
                                        <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualLogicalReads.ToString("N0")</span></div>
                                    }
                                }
                                @if (Node.ActualPhysicalReads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Physical Reads</span><span class="prop-value">@Node.ActualPhysicalReads.ToString("N0")</span></div>
                                    @if (Node.PerThreadStats.Count > 1)
                                    {
                                        @foreach (var t in Node.PerThreadStats.Where(t => t.ActualPhysicalReads > 0))
                                        {
                                            <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualPhysicalReads.ToString("N0")</span></div>
                                        }
                                    }
                                }
                                @if (Node.ActualScans > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Scans</span><span class="prop-value">@Node.ActualScans.ToString("N0")</span></div>
                                    @if (Node.PerThreadStats.Count > 1)
                                    {
                                        @foreach (var t in Node.PerThreadStats.Where(t => t.ActualScans > 0))
                                        {
                                            <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualScans.ToString("N0")</span></div>
                                        }
                                    }
                                }
                                @if (Node.ActualReadAheads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Read-Ahead Reads</span><span class="prop-value">@Node.ActualReadAheads.ToString("N0")</span></div>
                                    @if (Node.PerThreadStats.Count > 1)
                                    {
                                        @foreach (var t in Node.PerThreadStats.Where(t => t.ActualReadAheads > 0))
                                        {
                                            <div class="prop-row indent"><span class="prop-label">Thread @t.ThreadId</span><span class="prop-value">@t.ActualReadAheads.ToString("N0")</span></div>
                                        }
                                    }
                                }
                                @if (Node.ActualSegmentReads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Segment Reads</span><span class="prop-value">@Node.ActualSegmentReads.ToString("N0")</span></div>
                                }
                                @if (Node.ActualSegmentSkips > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">Segment Skips</span><span class="prop-value">@Node.ActualSegmentSkips.ToString("N0")</span></div>
                                }
                            </div>
                        </details>
                    }

                    @* Actual LOB I/O *@
                    @if (Node.ActualLobLogicalReads > 0 || Node.ActualLobPhysicalReads > 0 || Node.ActualLobReadAheads > 0)
                    {
                        <details class="prop-section">
                            <summary>Actual LOB I/O</summary>
                            <div class="prop-grid">
                                @if (Node.ActualLobLogicalReads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">LOB Logical Reads</span><span class="prop-value">@Node.ActualLobLogicalReads.ToString("N0")</span></div>
                                }
                                @if (Node.ActualLobPhysicalReads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">LOB Physical Reads</span><span class="prop-value">@Node.ActualLobPhysicalReads.ToString("N0")</span></div>
                                }
                                @if (Node.ActualLobReadAheads > 0)
                                {
                                    <div class="prop-row"><span class="prop-label">LOB Read-Aheads</span><span class="prop-value">@Node.ActualLobReadAheads.ToString("N0")</span></div>
                                }
                            </div>
                        </details>
                    }
                }

                @* Predicates *@
                @if (HasPredicates(Node))
                {
                    <details class="prop-section" open>
                        <summary>Predicates</summary>
                        <div class="prop-grid">
                            @if (!string.IsNullOrEmpty(Node.SeekPredicates))
                            {
                                <div class="prop-row full"><span class="prop-label">Seek</span><span class="prop-value code">@Node.SeekPredicates</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.Predicate))
                            {
                                <div class="prop-row full"><span class="prop-label">Predicate</span><span class="prop-value code">@Node.Predicate</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.HashKeysBuild))
                            {
                                <div class="prop-row full"><span class="prop-label">Hash Keys (Build)</span><span class="prop-value code">@Node.HashKeysBuild</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.HashKeysProbe))
                            {
                                <div class="prop-row full"><span class="prop-label">Hash Keys (Probe)</span><span class="prop-value code">@Node.HashKeysProbe</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.BuildResidual))
                            {
                                <div class="prop-row full"><span class="prop-label">Build Residual</span><span class="prop-value code">@Node.BuildResidual</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.ProbeResidual))
                            {
                                <div class="prop-row full"><span class="prop-label">Probe Residual</span><span class="prop-value code">@Node.ProbeResidual</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.MergeResidual))
                            {
                                <div class="prop-row full"><span class="prop-label">Merge Residual</span><span class="prop-value code">@Node.MergeResidual</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.PassThru))
                            {
                                <div class="prop-row full"><span class="prop-label">Pass Through</span><span class="prop-value code">@Node.PassThru</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.SetPredicate))
                            {
                                <div class="prop-row full"><span class="prop-label">Set Predicate</span><span class="prop-value code">@Node.SetPredicate</span></div>
                            }
                            @if (Node.GuessedSelectivity)
                            {
                                <div class="prop-row"><span class="prop-label">Guessed Selectivity</span><span class="prop-value flag warn">Yes</span></div>
                            }
                        </div>
                    </details>
                }

                @* Output *@
                @if (!string.IsNullOrEmpty(Node.OutputColumns))
                {
                    <details class="prop-section">
                        <summary>Output</summary>
                        <div class="prop-grid">
                            <div class="prop-row full"><span class="prop-label">Columns</span><span class="prop-value code">@Node.OutputColumns</span></div>
                        </div>
                    </details>
                }

                @* Operator Details *@
                @if (HasOperatorDetails(Node))
                {
                    <details class="prop-section">
                        <summary>Operator Details</summary>
                        <div class="prop-grid">
                            @if (!string.IsNullOrEmpty(Node.OrderBy))
                            {
                                <div class="prop-row full"><span class="prop-label">Order By</span><span class="prop-value code">@Node.OrderBy</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.GroupBy))
                            {
                                <div class="prop-row full"><span class="prop-label">Group By</span><span class="prop-value code">@Node.GroupBy</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.TopExpression))
                            {
                                <div class="prop-row"><span class="prop-label">Top</span><span class="prop-value">@Node.TopExpression@(Node.IsPercent ? " PERCENT" : "")@(Node.WithTies ? " WITH TIES" : "")</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.OffsetExpression))
                            {
                                <div class="prop-row"><span class="prop-label">Offset</span><span class="prop-value">@Node.OffsetExpression</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.InnerSideJoinColumns))
                            {
                                <div class="prop-row full"><span class="prop-label">Inner Join Cols</span><span class="prop-value code">@Node.InnerSideJoinColumns</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.OuterSideJoinColumns))
                            {
                                <div class="prop-row full"><span class="prop-label">Outer Join Cols</span><span class="prop-value code">@Node.OuterSideJoinColumns</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.OuterReferences))
                            {
                                <div class="prop-row full"><span class="prop-label">Outer References</span><span class="prop-value code">@Node.OuterReferences</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.DefinedValues))
                            {
                                <div class="prop-row full"><span class="prop-label">Defined Values</span><span class="prop-value code">@Node.DefinedValues</span></div>
                            }
                            @if (Node.ManyToMany)
                            {
                                <div class="prop-row"><span class="prop-label">Many to Many</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.SortDistinct)
                            {
                                <div class="prop-row"><span class="prop-label">Sort Distinct</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.BitmapCreator)
                            {
                                <div class="prop-row"><span class="prop-label">Bitmap Creator</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.NLOptimized)
                            {
                                <div class="prop-row"><span class="prop-label">NL Optimized</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.WithOrderedPrefetch)
                            {
                                <div class="prop-row"><span class="prop-label">Ordered Prefetch</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.WithUnorderedPrefetch)
                            {
                                <div class="prop-row"><span class="prop-label">Unordered Prefetch</span><span class="prop-value flag">Yes</span></div>
                            }
                            @if (Node.NonClusteredIndexCount > 0)
                            {
                                <div class="prop-row"><span class="prop-label">NC Indexes</span><span class="prop-value">@Node.NonClusteredIndexCount maintained</span></div>
                                @foreach (var ncIdx in Node.NonClusteredIndexNames)
                                {
                                    <div class="prop-row indent"><span class="prop-label"></span><span class="prop-value code">@ncIdx</span></div>
                                }
                            }
                            @if (!string.IsNullOrEmpty(Node.HashKeys))
                            {
                                <div class="prop-row full"><span class="prop-label">Hash Keys</span><span class="prop-value code">@Node.HashKeys</span></div>
                            }
                            @if (!string.IsNullOrEmpty(Node.PartitionColumns))
                            {
